# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-JS-LODASH-567487:
    - '*':
        reason: No direct usage, transitive dependency
        expires: 2024-06-01T12:00:00.000Z
        created: 2024-01-01T12:00:00.000Z
# patches apply the minimum changes required to fix a vulnerability
patch:
  'npm:lodash:20180126':
    - patch: 'SNYK-JS-LODASH-73639'
      patched: '2018-07-04T06:58:40.696Z'
      version: '4.17.4'
  'npm:minimatch:20160620':
    - patch: 'SNYK-JS-MINIMATCH-308966'
      patched: '2016-11-30T21:18:33.000Z'
      version: '3.0.2'
exclude:
  devDependencies: false
